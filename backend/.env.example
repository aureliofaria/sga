# Copy this file to .env and adjust the values.

# Prisma / SQLite database location (relative to the prisma/ schema directory).
DATABASE_URL="file:./dev.db"

# Secret used to sign and verify JWTs. REQUIRED in production — the server
# refuses to start without it. Generate a long random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="change-me-in-production"

# Token lifetime (zeit/ms format).
JWT_EXPIRES_IN="7d"

# HTTP port for the API.
PORT=4000

# Comma-separated list of allowed CORS origins (the frontend dev server).
CORS_ORIGINS="http://localhost:5173"

# Set to "production" to enforce strict secret handling.
NODE_ENV="development"
