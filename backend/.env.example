# Copie para .env e ajuste os valores.

# Ambiente: "production" exige JWT_SECRET definido (a app não sobe sem ele).
NODE_ENV=development

# Porta da API (e do app inteiro quando SERVE_FRONTEND=true).
PORT=3001

# Segredo de assinatura dos tokens JWT.
# OBRIGATÓRIO em produção. Gere um valor forte, ex.: openssl rand -hex 32
JWT_SECRET=

# Origens permitidas para CORS (separadas por vírgula).
# Dev: http://localhost:5173
# Rede interna em processo único: dispensável (frontend na mesma origem).
CORS_ORIGIN=http://localhost:5173

# String de conexão do banco (Prisma/SQLite por padrão).
DATABASE_URL="file:./dev.db"

# Servir o frontend (build em frontend/dist) pelo próprio backend.
# Ative no deploy de processo único na rede interna (acesso por http://<ip>:PORT).
# Deixe false em desenvolvimento (use o Vite em :5173).
SERVE_FRONTEND=false

# Notificações por canais externos (Teams/Outlook). Mantenha false até haver
# conta corporativa M365 + validação humana — hoje só IN_APP é entregue.
NOTIFICATIONS_EXTERNAL_ENABLED=false

# Intervalo (ms) do agendador in-process de escalonamento temporal (Passo 11).
# Só roda quando o backend é executado diretamente (não em testes). Padrão 600000 (10 min).
ESCALATION_INTERVAL_MS=600000

# ───────────────────────────────────────────────────────────────────────────
# Exemplo de produção em servidor local / rede interna (processo único):
#   NODE_ENV=production
#   PORT=80
#   JWT_SECRET=<openssl rand -hex 32>
#   DATABASE_URL="file:./dev.db"
#   SERVE_FRONTEND=true
#   # CORS_ORIGIN pode ficar como está — mesma origem dispensa CORS.
# ───────────────────────────────────────────────────────────────────────────
