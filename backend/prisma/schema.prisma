generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         String      @default("USER")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  initiatedRequests Request[]     @relation("Initiator")
  targetedRequests  Request[]     @relation("TargetEmployee")
  assignedTasks     RequestTask[]
  approvals         Approval[]
  comments          Comment[]
  notifications     Notification[]
  notificationPreferences NotificationPreference[]

  @@index([role])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]

  targetedRequests Request[] @relation("TargetDepartment")
}

model FlowTemplate {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        String
  isActive    Boolean    @default(true)
  steps       FlowStep[]
  requests    Request[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model FlowStep {
  id                 String               @id @default(cuid())
  flowTemplateId     String
  flowTemplate       FlowTemplate         @relation(fields: [flowTemplateId], references: [id], onDelete: Cascade)
  order              Int
  name               String
  description        String?
  requiredRole       String?
  requiredApprovers  Int                  @default(1)
  requiresAttachment Boolean              @default(false)
  deadlineHours      Int?
  authLevels         AuthorizationLevel[]
  tasks              RequestTask[]
  createdAt          DateTime             @default(now())

  @@index([flowTemplateId])
}

model AuthorizationLevel {
  id                String   @id @default(cuid())
  flowStepId        String
  flowStep          FlowStep @relation(fields: [flowStepId], references: [id], onDelete: Cascade)
  name              String
  // Monetary bounds stored as integer cents to avoid floating point errors.
  minValueCents     Int?
  maxValueCents     Int?
  requiredApprovers Int      @default(1)
  approverRole      String
  deadlineHours     Int?

  @@index([flowStepId])
}

model Request {
  id               String        @id @default(cuid())
  flowId           String
  flow             FlowTemplate  @relation(fields: [flowId], references: [id], onDelete: Restrict)
  initiatorId      String
  initiator        User          @relation("Initiator", fields: [initiatorId], references: [id], onDelete: Restrict)
  title            String
  description      String?
  status           String        @default("PENDING")
  currentStep      Int           @default(0)
  // Onboarding/offboarding targets reference real entities for integrity.
  targetEmployeeId   String?
  targetEmployee     User?       @relation("TargetEmployee", fields: [targetEmployeeId], references: [id], onDelete: SetNull)
  targetDepartmentId String?
  targetDepartment   Department? @relation("TargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: SetNull)
  startDate        DateTime?
  // Monetary amount stored as integer cents.
  amountCents      Int?
  currency         String        @default("BRL")
  supplier         String?
  costCenter       String?
  justification    String?
  tasks            RequestTask[]
  attachments      Attachment[]
  approvals        Approval[]
  auditLogs        AuditLog[]
  comments         Comment[]
  notifications    Notification[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([currentStep])
  @@index([initiatorId])
  @@index([flowId])
}

model RequestTask {
  id          String       @id @default(cuid())
  requestId   String
  request     Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepId      String
  step        FlowStep     @relation(fields: [stepId], references: [id], onDelete: Restrict)
  assigneeId  String
  assignee    User         @relation(fields: [assigneeId], references: [id], onDelete: Restrict)
  title       String
  description String?
  status      String       @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([requestId])
}

model Attachment {
  id           String       @id @default(cuid())
  requestId    String?
  request      Request?     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  taskId       String?
  task         RequestTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  storagePath  String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model Approval {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation(fields: [approverId], references: [id], onDelete: Restrict)
  stepOrder  Int
  decision   String
  comments   String?
  createdAt  DateTime @default(now())

  // Four-eyes integrity: a given approver may only register one decision per step.
  @@unique([requestId, approverId, stepOrder])
  @@index([requestId])
}

model AuditLog {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([requestId])
}

// Per-step collaboration thread. `stepOrder` null = comment on the request as a
// whole; otherwise the comment is scoped to that flow step.
model Comment {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepOrder Int?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([requestId, stepOrder])
}

// User-configurable delivery preferences. IN_APP is delivered immediately;
// external channels (TEAMS/OUTLOOK) are stored but only dispatched once M365
// integration is enabled — see Notification/notify service.
model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String // IN_APP | TEAMS | OUTLOOK
  eventType String // TASK_ASSIGNED | REQUEST_REJECTED | REQUEST_COMPLETED | COMMENT_ADDED
  enabled   Boolean @default(true)

  @@unique([userId, channel, eventType])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String?
  request   Request?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  channel   String    @default("IN_APP") // IN_APP | TEAMS | OUTLOOK
  // IN_APP: UNREAD -> READ. External channels are created as PENDING and would
  // move to SENT by a future dispatcher (currently gated off).
  status    String    @default("UNREAD")
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, status])
}
