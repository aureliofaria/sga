generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 String      @id @default(cuid())
  name               String
  email              String      @unique
  passwordHash       String
  role               String      @default("USER")
  requestPermissions String? // JSON array of allowed request types; null = todos os tipos
  departmentId       String?
  department         Department? @relation(fields: [departmentId], references: [id])
  sectorId           String?
  sector             Sector?     @relation("SectorMembers", fields: [sectorId], references: [id])
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  initiatedRequests       Request[]                @relation("Initiator")
  assignedTasks           RequestTask[]
  approvals               Approval[]
  forwardedApprovals      Approval[]               @relation("ApprovalForwardTarget")
  sectorRoles             SectorMember[]
  comments                Comment[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]

  // Inventário patrimonial
  assetsInPossession    Asset[]          @relation("AssetUser")
  assetMovementsFrom    AssetMovement[]  @relation("MovOrigemUser")
  assetMovementsTo      AssetMovement[]  @relation("MovDestinoUser")
  assetMovementsCreated AssetMovement[]  @relation("MovCreator")
  inventoryCounts       InventoryCount[] @relation("InventoryCountCreator")

  // Checklist
  checklistItemsChecked RequestChecklistItem[]

  // Escalonamento temporal (Fase 0 · Passo 11): tarefas cuja justificativa de
  // atraso foi registrada por este usuário.
  delayJustifications RequestTask[] @relation("TaskDelayJustifier")

  // Parâmetros financeiros (Fase 0 · Passo 12): teto/override editados por este usuário.
  financeParamEdits FinanceParam[] @relation("FinanceParamEditor")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  users     User[]

  // Inventário patrimonial
  assets             Asset[]
  assetMovementsFrom AssetMovement[]  @relation("MovOrigemDept")
  assetMovementsTo   AssetMovement[]  @relation("MovDestinoDept")
  inventoryCounts    InventoryCount[]
}

model Sector {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        SectorMember[]
  users          User[]         @relation("SectorMembers")
  flowTemplates  FlowTemplate[] @relation("FlowSector")
  flowSteps      FlowStep[]     @relation("StepSector")
  activatedSteps FlowStep[]     @relation("StepActivationSector")
  requests       Request[]      @relation("RequestSector")
  resourceItems  ResourceItem[] @relation("SectorResources")
  financeParams  FinanceParam[]
}

model SectorMember {
  id        String   @id @default(cuid())
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String // legado: LIDER, PROTETOR (mantido p/ compat; ver `level`)
  // Fase 0 — hierarquia: LIDER_1 (1 por setor, obrigatório/único), LIDER_2 (0..n), MEMBRO (0..n).
  level     String   @default("MEMBRO")
  // Membro reporta a um LIDER_2 ou direto ao LIDER_1 (apreciação do pedido).
  reportsToId String?
  reportsTo   SectorMember?  @relation("MemberReports", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports     SectorMember[] @relation("MemberReports")
  // Suplência: LIDER_1 delega a um LIDER_2 por um período (evita travar o setor).
  delegateToId  String?
  delegateTo    SectorMember?  @relation("MemberDelegate", fields: [delegateToId], references: [id], onDelete: SetNull)
  delegatedFrom SectorMember[] @relation("MemberDelegate")
  delegateUntil DateTime?
  createdAt DateTime @default(now())

  @@unique([sectorId, userId, role])
}

model FlowTemplate {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        String
  scope       String     @default("INTRA") // INTRA, INTER
  sectorId    String?
  sector      Sector?    @relation("FlowSector", fields: [sectorId], references: [id])
  isActive    Boolean    @default(true)
  steps       FlowStep[]
  requests    Request[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model FlowStep {
  id                 String               @id @default(cuid())
  flowTemplateId     String
  flowTemplate       FlowTemplate         @relation(fields: [flowTemplateId], references: [id], onDelete: Cascade)
  order              Int
  name               String
  description        String?
  requiredRole       String?
  requiresAttachment Boolean              @default(false)
  deadlineHours      Int?
  handlingSectorId   String?
  handlingSector     Sector?              @relation("StepSector", fields: [handlingSectorId], references: [id])
  slaExpiry          String               @default("KEEP_WITH_RESPONSIBLE")
  conditions         String?
  activateOnSectorId String?
  activateOnSector   Sector?              @relation("StepActivationSector", fields: [activateOnSectorId], references: [id])
  collectsResources  Boolean              @default(false)
  // Fase 0 · Passo 10: rótulo humano de exibição quando a solicitação está nesta etapa.
  statusLabel        String?
  // Fase 0 · Passo 11: overrides opcionais da cadência de escalonamento (em dias
  // desde a criação da tarefa). Nulo → usa o padrão fixo 2/3/7.
  escalationDay1     Int?
  escalationDay2     Int?
  escalationDay3     Int?
  authLevels         AuthorizationLevel[]
  tasks              RequestTask[]
  formFields         FormField[]
  checklistItems     ChecklistItem[]
  createdAt          DateTime             @default(now())
}

// ===========================================================================
// Campos dinâmicos por etapa (Fase 0 · Passo 7) — definição (FormField) e
// valores preenchidos por solicitação (RequestFieldValue). O gancho de PII é o
// `sensitiveType`: quando setado, o valor é mascarado na leitura conforme a
// política do Passo 4 (fieldMasking.ts).
// ===========================================================================

model FormField {
  id            String              @id @default(cuid())
  flowStepId    String
  flowStep      FlowStep            @relation(fields: [flowStepId], references: [id], onDelete: Cascade)
  key           String // snake_case, único na etapa
  label         String
  type          String // TEXT|TEXTAREA|NUMBER|DATE|SELECT|EMAIL|CPF|RG|MONEY|PHONE
  required      Boolean             @default(false)
  options       String? // JSON array p/ SELECT
  order         Int                 @default(0)
  sensitiveType String? // SensitiveType ('CPF'|'RG'|'SALARY'|'EMAIL_PERSONAL'|'PHONE_PERSONAL') — gancho do mascaramento
  values        RequestFieldValue[]
  createdAt     DateTime            @default(now())

  @@unique([flowStepId, key])
  @@index([flowStepId])
}

model RequestFieldValue {
  id        String    @id @default(cuid())
  requestId String
  request   Request   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  fieldId   String
  field     FormField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  value     String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([requestId, fieldId])
  @@index([requestId])
  @@index([fieldId])
}

model AuthorizationLevel {
  id                String   @id @default(cuid())
  flowStepId        String
  flowStep          FlowStep @relation(fields: [flowStepId], references: [id], onDelete: Cascade)
  name              String
  minValueCents     Int?
  maxValueCents     Int?
  requiredApprovers Int      @default(1)
  approverRole      String
  deadlineHours     Int?
}

model Request {
  id               String            @id @default(cuid())
  flowId           String
  flow             FlowTemplate      @relation(fields: [flowId], references: [id])
  initiatorId      String
  initiator        User              @relation("Initiator", fields: [initiatorId], references: [id])
  sectorId         String?
  sector           Sector?           @relation("RequestSector", fields: [sectorId], references: [id])
  title            String
  description      String?
  status           String            @default("PENDING")
  currentStep      Int               @default(0)
  // Etapa para a qual o pedido retorna quando o solicitante reenvia após uma
  // SOLICITAÇÃO DE CORREÇÃO (status AWAITING_CORRECTION). Nulo fora desse estado.
  correctionReturnStep Int?
  targetEmployee   String?
  targetDepartment String?
  startDate        String?
  amountCents      Int?
  currency         String            @default("BRL")
  supplier         String?
  costCenter       String?
  justification    String?
  vacancyType      String?
  replacementName  String?
  // Subfluxo pai↔filho (Fase 0 · Passo 9): vínculo opcional com a solicitação
  // que originou esta (ex.: vaga → compra). SetNull para não cascatear exclusões.
  parentRequestId  String?
  parent           Request?          @relation("RequestParentChild", fields: [parentRequestId], references: [id], onDelete: SetNull)
  children         Request[]         @relation("RequestParentChild")
  // Fase 0 · Passo 10: rótulo de exibição DENORMALIZADO da etapa corrente.
  // Espelha FlowStep.statusLabel da etapa atual para leitura eficiente na lista
  // (sem joins). Atualizado na criação e no avanço de etapa; zerado na conclusão.
  statusLabel      String?
  tasks            RequestTask[]
  resources        RequestResource[]
  attachments      Attachment[]
  approvals        Approval[]
  auditLogs        AuditLog[]
  assetMovements   AssetMovement[]
  comments         Comment[]
  notifications    Notification[]
  fieldValues      RequestFieldValue[]
  checklistItems   RequestChecklistItem[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepOrder Int?
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  body      String
  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([requestId, stepOrder])
}

model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String // IN_APP | TEAMS | OUTLOOK
  eventType String // TASK_ASSIGNED | REQUEST_REJECTED | REQUEST_COMPLETED | COMMENT_ADDED
  enabled   Boolean @default(true)

  @@unique([userId, channel, eventType])
  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestId String?
  request   Request?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  channel   String    @default("IN_APP") // IN_APP | TEAMS | OUTLOOK
  status    String    @default("UNREAD") // IN_APP: UNREAD -> READ; externos: PENDING -> SENT (dispatcher futuro)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  @@index([userId, status])
}

model RequestTask {
  id           String       @id @default(cuid())
  requestId    String
  request      Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepId       String
  step         FlowStep     @relation(fields: [stepId], references: [id])
  assigneeId   String
  assignee     User         @relation(fields: [assigneeId], references: [id])
  title        String
  description  String?
  status       String       @default("PENDING")
  dueDate      DateTime?
  completedAt  DateTime?
  notes        String?
  slaEscalated Boolean      @default(false)
  // Escalonamento temporal (Fase 0 · Passo 11): estágio mais severo já disparado
  // (0 = nenhum, 1 = lembrete ao responsável, 2 = líder, 3 = transferência).
  escalationStage    Int       @default(0)
  // Justificativa de atraso registrada pelo responsável (ou ADMIN).
  delayJustification String?
  delayJustifiedAt   DateTime?
  delayJustifiedById String?
  delayJustifiedBy   User?     @relation("TaskDelayJustifier", fields: [delayJustifiedById], references: [id], onDelete: SetNull)
  attachments  Attachment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Attachment {
  id           String       @id @default(cuid())
  requestId    String?
  request      Request?     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  taskId       String?
  task         RequestTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  storagePath  String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model Approval {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation(fields: [approverId], references: [id])
  stepOrder  Int
  // APPROVED | REJECTED | CORRECTION_REQUESTED | FORWARDED
  decision   String
  comments   String?
  // Destino de um ENCAMINHAMENTO (decision=FORWARDED): usuário específico OU papel
  // (modelo de fila). Exatamente um dos dois é preenchido no encaminhamento.
  forwardedToId   String?
  forwardedTo     User?    @relation("ApprovalForwardTarget", fields: [forwardedToId], references: [id])
  forwardedToRole String?
  // Rodada de decisão da etapa. Reenvios após correção incrementam o round, de
  // modo que decisões de rodadas anteriores não contam para a completude atual.
  round      Int      @default(0)
  createdAt  DateTime @default(now())

  // Impede que o mesmo aprovador registre mais de uma decisão na mesma etapa+rodada,
  // o que poderia burlar a exigência de múltiplos aprovadores (requiredApprovers).
  @@unique([requestId, stepOrder, approverId, round])
}

model AuditLog {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model ResourceItem {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("EQUIPMENT") // EQUIPMENT | SYSTEM_ACCESS | OTHER
  sectorId  String?
  sector    Sector?  @relation("SectorResources", fields: [sectorId], references: [id])
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  requestResources RequestResource[]
}

model RequestResource {
  id             String       @id @default(cuid())
  requestId      String
  request        Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  resourceItemId String
  resourceItem   ResourceItem @relation(fields: [resourceItemId], references: [id])
  quantity       Int          @default(1)
  notes          String?
  status         String       @default("PENDING") // PENDING | ALLOCATED | RETURNED
  // Ponte com o inventário patrimonial: unidade física que cumpre esta linha de
  // intenção (quando aplicável). Nula para itens intangíveis (ex.: acessos).
  assetId        String?
  asset          Asset?       @relation(fields: [assetId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([requestId, resourceItemId])
}

// ===========================================================================
// Inventário patrimonial (TI e Administrativo) — rastreio de ativos físicos,
// movimentações (log imutável, vinculável a uma Request do workflow) e contagem.
// ===========================================================================

model InventoryItem {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  // TI | ADMINISTRATIVO
  type        String
  // HARDWARE | PERIFERICO | SMARTPHONE | CHIP | MOBILIARIO | OUTROS
  category    String
  brand       String?
  model       String?
  unit        String   @default("UN")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

model Warehouse {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

model Asset {
  id                String        @id @default(cuid())
  itemId            String
  item              InventoryItem @relation(fields: [itemId], references: [id])
  // número de patrimônio / etiqueta
  tag               String?       @unique
  serialNumber      String?
  // IMEI para smartphones
  imei              String?
  // número da linha para chips/SIM cards
  phoneNumber       String?
  // DISPONIVEL | ATIVO | MANUTENCAO | EMPRESTADO | RESERVADO | DESCARTADO
  status            String        @default("DISPONIVEL")
  // NOVO | BOM | REGULAR | RUIM
  condition         String        @default("BOM")
  purchaseDate      DateTime?
  supplier          String?
  invoiceNumber     String?
  // valor da NF em centavos (Int), consistente com o restante do APROVA
  invoiceValueCents Int?
  // localização (almoxarifado — quando não alocado a departamento)
  warehouseId       String?
  warehouse         Warehouse?    @relation(fields: [warehouseId], references: [id])
  // setor/departamento responsável atual
  departmentId      String?
  department        Department?   @relation(fields: [departmentId], references: [id])
  // usuário em posse atual
  userId            String?
  user              User?         @relation("AssetUser", fields: [userId], references: [id])
  notes             String?
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  movements        AssetMovement[]
  countItems       InventoryCountItem[]
  requestResources RequestResource[]
}

model AssetMovement {
  id               String      @id @default(cuid())
  assetId          String
  asset            Asset       @relation(fields: [assetId], references: [id])
  // ENTRADA | ALOCACAO | DEVOLUCAO | MANUTENCAO | RETORNO_MANUTENCAO
  // DESCARTE | TRANSFERENCIA | EMPRESTIMO | AJUSTE_STATUS
  type             String
  movementDate     DateTime    @default(now())
  fromDepartmentId String?
  fromDepartment   Department? @relation("MovOrigemDept", fields: [fromDepartmentId], references: [id])
  toDepartmentId   String?
  toDepartment     Department? @relation("MovDestinoDept", fields: [toDepartmentId], references: [id])
  fromUserId       String?
  fromUser         User?       @relation("MovOrigemUser", fields: [fromUserId], references: [id])
  toUserId         String?
  toUser           User?       @relation("MovDestinoUser", fields: [toUserId], references: [id])
  previousStatus   String?
  newStatus        String?
  // vínculo opcional com solicitação do workflow APROVA
  requestId        String?
  request          Request?    @relation(fields: [requestId], references: [id])
  reason           String?
  notes            String?
  createdById      String
  createdBy        User        @relation("MovCreator", fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
}

model InventoryCount {
  id           String      @id @default(cuid())
  // RASCUNHO | EM_ANDAMENTO | CONCLUIDA | CANCELADA
  status       String      @default("RASCUNHO")
  // GERAL | TI | ADMINISTRATIVO | SETOR
  type         String      @default("GERAL")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  notes        String?
  createdById  String
  createdBy    User        @relation("InventoryCountCreator", fields: [createdById], references: [id])
  completedAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  items InventoryCountItem[]
}

model InventoryCountItem {
  id            String         @id @default(cuid())
  countId       String
  count         InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset          @relation(fields: [assetId], references: [id])
  // encontrado na contagem física?
  found         Boolean?
  foundLocation String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([countId, assetId])
}

// ===========================================================================
// Checklist por etapa (Fase 0 · Passo 8) — definição (ChecklistItem) e estados
// por solicitação (RequestChecklistItem). O campo `condition` armazena JSON
// fechado descrevendo a condição de aplicabilidade do item; null = sempre visível.
// ===========================================================================

model ChecklistItem {
  id         String                 @id @default(cuid())
  flowStepId String
  flowStep   FlowStep               @relation(fields: [flowStepId], references: [id], onDelete: Cascade)
  label      String
  order      Int                    @default(0)
  required   Boolean                @default(true)
  condition  String?                // JSON fechado; null = sempre aplicável
  createdAt  DateTime               @default(now())
  states     RequestChecklistItem[]

  @@index([flowStepId])
}

model RequestChecklistItem {
  id          String        @id @default(cuid())
  requestId   String
  request     Request       @relation(fields: [requestId], references: [id], onDelete: Cascade)
  itemId      String
  item        ChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  checked     Boolean       @default(false)
  checkedById String?
  checkedBy   User?         @relation(fields: [checkedById], references: [id], onDelete: SetNull)
  checkedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([requestId, itemId])
  @@index([requestId])
  @@index([itemId])
}

// ===========================================================================
// Parâmetros financeiros (Fase 0 · Passo 12) — teto orçamentário mensal por
// setor, consumo (calculado a partir das solicitações concluídas no mês ou
// substituído por um override manual) e auditoria das edições. Valores SEMPRE
// em centavos inteiros.
// ===========================================================================

model FinanceParam {
  id                    String   @id @default(cuid())
  sectorId              String
  sector                Sector   @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  year                  Int
  month                 Int // 1–12
  ceilingCents          Int // teto manual
  overrideConsumedCents Int? // override manual; quando presente SUBSTITUI o consumido calculado
  updatedById           String
  updatedBy             User     @relation("FinanceParamEditor", fields: [updatedById], references: [id])
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())

  @@unique([sectorId, year, month])
  @@index([sectorId])
}

model FinanceParamAuditLog {
  id        String   @id @default(cuid())
  sectorId  String
  year      Int
  month     Int
  userId    String
  userName  String
  action    String // FINANCE_PARAM_UPSERTED | FINANCE_OVERRIDE_SET | FINANCE_OVERRIDE_CLEARED | FINANCE_PARAM_DELETED
  details   String? // JSON {before, after}
  createdAt DateTime @default(now())

  @@index([sectorId])
  @@index([userId])
}

// Trilha PERSISTENTE da concessão/revogação de suplência do Líder I (Fase 0 ·
// Passo 13). Transferência de autoridade precisa de auditoria consultável. O
// AuditLog principal exige requestId (FK), então usamos tabela dedicada — mesmo
// padrão do FinanceParamAuditLog.
model DelegationAuditLog {
  id               String    @id @default(cuid())
  sectorId         String
  lider1MemberId   String
  delegateMemberId String?
  delegateUserId   String?
  action           String // DELEGATION_SET | DELEGATION_CLEARED
  until            DateTime?
  byUserId         String
  byUserName       String
  createdAt        DateTime  @default(now())

  @@index([sectorId])
  @@index([byUserId])
}
