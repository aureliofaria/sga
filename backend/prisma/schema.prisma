generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  role         String      @default("USER")
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  initiatedRequests     Request[]        @relation("Initiator")
  assignedTasks         RequestTask[]
  approvals             Approval[]
  assetsInPossession    Asset[]          @relation("AssetUser")
  assetMovementsFrom    AssetMovement[]  @relation("MovOrigemUser")
  assetMovementsTo      AssetMovement[]  @relation("MovDestinoUser")
  assetMovementsCreated AssetMovement[]  @relation("MovCreator")
  inventoryCounts       InventoryCount[] @relation("InventoryCountCreator")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users              User[]
  assets             Asset[]
  assetMovementsFrom AssetMovement[]  @relation("MovOrigemDept")
  assetMovementsTo   AssetMovement[]  @relation("MovDestinoDept")
  inventoryCounts    InventoryCount[]
}

model FlowTemplate {
  id          String     @id @default(cuid())
  name        String
  description String?
  type        String
  isActive    Boolean    @default(true)
  steps       FlowStep[]
  requests    Request[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model FlowStep {
  id                 String               @id @default(cuid())
  flowTemplateId     String
  flowTemplate       FlowTemplate         @relation(fields: [flowTemplateId], references: [id], onDelete: Cascade)
  order              Int
  name               String
  description        String?
  requiredRole       String?
  requiresAttachment Boolean              @default(false)
  deadlineHours      Int?
  authLevels         AuthorizationLevel[]
  tasks              RequestTask[]
  createdAt          DateTime             @default(now())
}

model AuthorizationLevel {
  id                String   @id @default(cuid())
  flowStepId        String
  flowStep          FlowStep @relation(fields: [flowStepId], references: [id], onDelete: Cascade)
  name              String
  minValue          Float?
  maxValue          Float?
  requiredApprovers Int      @default(1)
  approverRole      String
  deadlineHours     Int?
}

model Request {
  id               String          @id @default(cuid())
  flowId           String
  flow             FlowTemplate    @relation(fields: [flowId], references: [id])
  initiatorId      String
  initiator        User            @relation("Initiator", fields: [initiatorId], references: [id])
  title            String
  description      String?
  status           String          @default("PENDING")
  currentStep      Int             @default(0)
  targetEmployee   String?
  targetDepartment String?
  startDate        String?
  amount           Float?
  currency         String          @default("BRL")
  supplier         String?
  costCenter       String?
  justification    String?
  tasks            RequestTask[]
  attachments      Attachment[]
  approvals        Approval[]
  auditLogs        AuditLog[]
  assetMovements   AssetMovement[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model RequestTask {
  id          String       @id @default(cuid())
  requestId   String
  request     Request      @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stepId      String
  step        FlowStep     @relation(fields: [stepId], references: [id])
  assigneeId  String
  assignee    User         @relation(fields: [assigneeId], references: [id])
  title       String
  description String?
  status      String       @default("PENDING")
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attachment {
  id           String       @id @default(cuid())
  requestId    String?
  request      Request?     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  taskId       String?
  task         RequestTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fileName     String
  originalName String
  fileSize     Int
  mimeType     String
  storagePath  String
  uploadedBy   String
  createdAt    DateTime     @default(now())
}

model Approval {
  id         String   @id @default(cuid())
  requestId  String
  request    Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approverId String
  approver   User     @relation(fields: [approverId], references: [id])
  stepOrder  Int
  decision   String
  comments   String?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  requestId String
  request   Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  userId    String
  userName  String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

// ─── Inventário ───────────────────────────────────────────────────────────────

// Catálogo de tipos/modelos de item
model InventoryItem {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  // TI | ADMINISTRATIVO
  type        String
  // HARDWARE | PERIFERICO | SMARTPHONE | CHIP | MOBILIARIO | OUTROS
  category    String
  brand       String?
  model       String?
  unit        String   @default("UN")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

// Almoxarifado / local de guarda (para itens não alocados a um setor)
model Warehouse {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets Asset[]
}

// Ativo físico individual — cada unidade patrimonial rastreada
model Asset {
  id            String        @id @default(cuid())
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id])
  // número de patrimônio / etiqueta
  tag           String?       @unique
  serialNumber  String?
  // IMEI para smartphones
  imei          String?
  // número da linha para chips/SIM cards
  phoneNumber   String?
  // DISPONIVEL | ATIVO | MANUTENCAO | EMPRESTADO | RESERVADO | DESCARTADO
  status        String        @default("DISPONIVEL")
  // NOVO | BOM | REGULAR | RUIM
  condition     String        @default("BOM")
  purchaseDate  DateTime?
  supplier      String?
  invoiceNumber String?
  invoiceValue  Float?
  // localização (almoxarifado — quando não alocado a departamento)
  warehouseId   String?
  warehouse     Warehouse?    @relation(fields: [warehouseId], references: [id])
  // setor/departamento responsável atual
  departmentId  String?
  department    Department?   @relation(fields: [departmentId], references: [id])
  // usuário em posse atual
  userId        String?
  user          User?         @relation("AssetUser", fields: [userId], references: [id])
  notes         String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  movements  AssetMovement[]
  countItems InventoryCountItem[]
}

// Registro imutável de cada movimentação de ativo patrimonial
model AssetMovement {
  id               String      @id @default(cuid())
  assetId          String
  asset            Asset       @relation(fields: [assetId], references: [id])
  // ENTRADA | ALOCACAO | DEVOLUCAO | MANUTENCAO | RETORNO_MANUTENCAO
  // DESCARTE | TRANSFERENCIA | EMPRESTIMO | AJUSTE_STATUS
  type             String
  movementDate     DateTime    @default(now())
  fromDepartmentId String?
  fromDepartment   Department? @relation("MovOrigemDept", fields: [fromDepartmentId], references: [id])
  toDepartmentId   String?
  toDepartment     Department? @relation("MovDestinoDept", fields: [toDepartmentId], references: [id])
  fromUserId       String?
  fromUser         User?       @relation("MovOrigemUser", fields: [fromUserId], references: [id])
  toUserId         String?
  toUser           User?       @relation("MovDestinoUser", fields: [toUserId], references: [id])
  previousStatus   String?
  newStatus        String?
  // vínculo opcional com solicitação do workflow APROVA
  requestId        String?
  request          Request?    @relation(fields: [requestId], references: [id])
  reason           String?
  notes            String?
  createdById      String
  createdBy        User        @relation("MovCreator", fields: [createdById], references: [id])
  createdAt        DateTime    @default(now())
}

// Sessão de contagem física (inventário periódico)
model InventoryCount {
  id           String               @id @default(cuid())
  // RASCUNHO | EM_ANDAMENTO | CONCLUIDA | CANCELADA
  status       String               @default("RASCUNHO")
  // GERAL | TI | ADMINISTRATIVO | SETOR
  type         String               @default("GERAL")
  departmentId String?
  department   Department?          @relation(fields: [departmentId], references: [id])
  notes        String?
  createdById  String
  createdBy    User                 @relation("InventoryCountCreator", fields: [createdById], references: [id])
  completedAt  DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  items InventoryCountItem[]
}

// Item individual dentro de uma sessão de contagem
model InventoryCountItem {
  id            String         @id @default(cuid())
  countId       String
  count         InventoryCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  assetId       String
  asset         Asset          @relation(fields: [assetId], references: [id])
  // encontrado na contagem física?
  found         Boolean?
  foundLocation String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([countId, assetId])
}
